---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Grid background -->
  <div
    class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem]"
    aria-hidden="true"
  >
  </div>

  <!-- Radial fade -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-zinc-950 via-transparent to-zinc-950"
    aria-hidden="true"
  >
  </div>

  <!-- Blue glow blob -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] rounded-full bg-blue-600/8 blur-[120px] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Live badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-medium mb-10">
      <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse" aria-hidden="true"></span>
      Now live on Google Play
    </div>

    <!-- Brand mark -->
    <div class="flex items-center justify-center gap-4 mb-8">
      <div
        class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-2xl shadow-blue-500/40"
        aria-hidden="true"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-9 h-9 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.75"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </div>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-8xl font-black tracking-tight leading-none mb-6">
      <span class="text-white">Drake's</span>
      <br />
      <span
        class="bg-gradient-to-r from-blue-400 via-blue-500 to-blue-600 bg-clip-text text-transparent"
      >
        Workshop
      </span>
    </h1>

    <p class="text-xl sm:text-2xl text-zinc-400 max-w-2xl mx-auto mb-4 leading-relaxed font-light">
      Building
      <span class="text-white font-semibold">high-quality mobile applications</span>
       and
      <span class="text-white font-semibold">gaming experiences</span>
       for Android.
    </p>
    <p class="text-base text-zinc-500 max-w-xl mx-auto mb-12">
      Crafting tools and games that people actually use — shipped on Google Play.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/#apps"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-all duration-200 shadow-xl shadow-blue-500/25 hover:shadow-blue-500/40 hover:-translate-y-0.5"
      >
        Explore Apps
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="/#contact"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl border border-zinc-700 hover:border-zinc-500 text-zinc-300 hover:text-white font-semibold transition-all duration-200 hover:-translate-y-0.5"
      >
        Get in Touch
      </a>
    </div>

    <!-- Stats row -->
    <div
      class="mt-20 grid grid-cols-3 gap-8 max-w-sm mx-auto border-t border-white/5 pt-10"
    >
      <div class="text-center">
        <p class="text-2xl font-bold text-white">2+</p>
        <p class="text-xs text-zinc-500 uppercase tracking-widest mt-1">Apps</p>
      </div>
      <div class="text-center border-x border-white/5">
        <p class="text-2xl font-bold text-white">100%</p>
        <p class="text-xs text-zinc-500 uppercase tracking-widest mt-1">Free</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-white">Android</p>
        <p class="text-xs text-zinc-500 uppercase tracking-widest mt-1">Platform</p>
      </div>
    </div>
  </div>
</section>
