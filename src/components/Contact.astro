---
---

<section id="contact" class="relative py-28">
  <!-- Top glow divider -->
  <div
    class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-zinc-700/60 to-transparent"
    aria-hidden="true"
  >
  </div>

  <!-- Background gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-500/3 to-transparent pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-14">
        <p class="font-mono text-sm text-blue-400 uppercase tracking-widest mb-3">
          // Get In Touch
        </p>
        <h2 class="text-4xl sm:text-5xl font-black text-white mb-4 tracking-tight">Contact Us</h2>
        <p class="text-zinc-400 text-lg max-w-xl mx-auto leading-relaxed">
          Spotted a bug? Have feedback? Want to collaborate? We're happy to hear from you.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
        <!-- Email -->
        <a
          href="mailto:adrianmolina39@gmail.com"
          class="group flex items-center gap-4 p-5 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 transition-all duration-200 hover:shadow-lg hover:shadow-blue-500/5"
          aria-label="Send us an email"
        >
          <div
            class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-500/20 transition-colors"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-blue-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-xs text-zinc-500 uppercase tracking-widest mb-0.5">Support Email</p>
            <p
              class="text-white font-medium group-hover:text-blue-400 transition-colors truncate"
            >
              adrianmolina39@gmail.com
            </p>
          </div>
        </a>

        <!-- Response time -->
        <div
          class="flex items-center gap-4 p-5 rounded-2xl bg-zinc-900 border border-zinc-800"
        >
          <div
            class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center flex-shrink-0"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-green-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-xs text-zinc-500 uppercase tracking-widest mb-0.5">Response Time</p>
            <p class="text-white font-medium">Within 48 hours</p>
          </div>
        </div>
      </div>

      <!-- Reasons to contact -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        {
          [
            { icon: '🐛', title: 'Bug Reports', desc: 'Help us squash issues.' },
            { icon: '💡', title: 'Feature Ideas', desc: 'Suggest improvements.' },
            { icon: '🤝', title: 'Collaboration', desc: 'Work with the workshop.' },
          ].map((item) => (
            <div class="p-4 rounded-xl bg-zinc-900/60 border border-zinc-800/60 text-center">
              <span class="text-2xl mb-2 block" aria-hidden="true">
                {item.icon}
              </span>
              <p class="text-white text-sm font-semibold mb-1">{item.title}</p>
              <p class="text-zinc-500 text-xs">{item.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- Privacy notice -->
      <div class="rounded-xl bg-zinc-900/50 border border-zinc-800/60 p-4 text-center">
        <p class="text-zinc-500 text-sm">
          By reaching out, you agree to our
          <a
            href="/privacy"
            class="text-blue-400 hover:text-blue-300 underline underline-offset-2 transition-colors"
          >
            Privacy Policy
          </a>. Your information will never be sold or shared with third parties.
        </p>
      </div>
    </div>
  </div>
</section>
