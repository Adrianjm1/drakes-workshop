---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const effectiveDate = 'April 28, 2026';
const contactEmail = 'adrianmolina39@gmail.com';
const developerName = "Drake's Workshop";
const websiteUrl = 'https://drakesworkshop.dev';
---

<BaseLayout
  title="Privacy Policy — Drake's Workshop"
  description="Privacy Policy for Drake's Workshop Android applications. Learn how we collect, use, and protect your data in compliance with Google Play requirements."
>
  <Navbar />

  <main class="pt-24 pb-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-zinc-300 transition-colors mb-8"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Home
          </a>

          <div
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-400 text-xs font-medium mb-5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
            Legal Document
          </div>

          <h1 class="text-4xl sm:text-5xl font-black text-white mb-4 tracking-tight">
            Privacy Policy
          </h1>
          <p class="text-zinc-400 text-lg">
            <strong class="text-zinc-200">{developerName}</strong> is committed to protecting your privacy.
            This policy explains what data our applications collect, how it is used, and your rights as
            a user.
          </p>
          <p class="text-zinc-500 text-sm mt-4">
            <strong class="text-zinc-400">Effective Date:</strong>
            {effectiveDate}
          </p>
        </div>

        <!-- Divider -->
        <div class="h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent mb-12" aria-hidden="true"></div>

        <!-- Policy content -->
        <div class="space-y-10 text-zinc-400 leading-relaxed">

          <!-- 1. Introduction -->
          <section aria-labelledby="section-intro">
            <h2 id="section-intro" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">01.</span>
              Introduction
            </h2>
            <p>
              This Privacy Policy applies to all mobile applications and services published by
              <strong class="text-zinc-200">{developerName}</strong> ("we", "us", or "our") on the
              Google Play Store, including but not limited to <em>Arena Clash</em> and
              <em>WorkFind</em>. By downloading, installing, or using any of our applications, you
              agree to the practices described in this Privacy Policy.
            </p>
            <p class="mt-3">
              If you do not agree with this policy, please do not install or use our applications.
              We may update this policy from time to time; continued use of our apps after changes
              are posted constitutes your acceptance of the revised policy.
            </p>
          </section>

          <!-- 2. Information We Collect -->
          <section aria-labelledby="section-collect">
            <h2 id="section-collect" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">02.</span>
              Information We Collect
            </h2>

            <h3 class="text-base font-semibold text-zinc-200 mt-4 mb-2">
              2.1 Information Collected Automatically
            </h3>
            <p>When you use our applications, the following data may be collected automatically:</p>
            <ul class="mt-3 space-y-2 list-none pl-0">
              {[
                'Device information (device model, operating system version, unique device identifiers)',
                'App usage data (features accessed, time spent, in-app events)',
                'Crash reports and diagnostic information',
                'Network information (IP address, mobile network details)',
                'General location data (country/region, derived from IP address only)',
              ].map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <h3 class="text-base font-semibold text-zinc-200 mt-6 mb-2">
              2.2 Information You Provide
            </h3>
            <p>
              Certain features may ask you to voluntarily provide information, such as:
            </p>
            <ul class="mt-3 space-y-2 list-none pl-0">
              {[
                'Email address (for support requests or account creation)',
                'Username or display name (for gaming features)',
                'Feedback or messages sent to our support team',
              ].map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <h3 class="text-base font-semibold text-zinc-200 mt-6 mb-2">
              2.3 What We Do Not Collect
            </h3>
            <p>
              We do <strong class="text-zinc-200">not</strong> collect precise GPS location, contacts,
              photos, financial information, or any data unnecessary for the core function of the application.
            </p>
          </section>

          <!-- 3. How We Use Your Information -->
          <section aria-labelledby="section-use">
            <h2 id="section-use" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">03.</span>
              How We Use Your Information
            </h2>
            <p>We use the collected information solely to:</p>
            <ul class="mt-3 space-y-2 list-none pl-0">
              {[
                'Operate, maintain, and improve our applications',
                'Diagnose and fix technical issues and crashes',
                'Respond to support requests and user feedback',
                'Understand how users interact with our apps (aggregate analytics only)',
                'Comply with legal obligations',
              ].map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="mt-4">
              We do <strong class="text-zinc-200">not</strong> sell, rent, or trade your personal information
              to any third party for marketing purposes.
            </p>
          </section>

          <!-- 4. Third-Party Services -->
          <section aria-labelledby="section-third-party">
            <h2 id="section-third-party" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">04.</span>
              Third-Party Services
            </h2>
            <p>
              Our applications may use third-party services that have their own privacy policies.
              These services may collect information used to identify you. Below is a list of
              third-party service providers we may use:
            </p>

            <div class="mt-5 space-y-4">
              {[
                {
                  name: 'Google Play Services',
                  purpose: 'Core Android platform services, app distribution, and licensing.',
                  link: 'https://policies.google.com/privacy',
                },
                {
                  name: 'Firebase (Google Analytics for Firebase)',
                  purpose: 'Aggregate app usage analytics and crash reporting (Firebase Crashlytics).',
                  link: 'https://firebase.google.com/support/privacy',
                },
                {
                  name: 'Google AdMob (if applicable)',
                  purpose: 'Serving advertisements within free applications.',
                  link: 'https://support.google.com/admob/answer/6128543',
                },
              ].map((service) => (
                <div class="rounded-xl bg-zinc-900 border border-zinc-800 p-4">
                  <p class="text-zinc-200 font-semibold text-sm mb-1">{service.name}</p>
                  <p class="text-zinc-400 text-sm mb-2">{service.purpose}</p>
                  <a
                    href={service.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-400 hover:text-blue-300 text-xs inline-flex items-center gap-1 transition-colors"
                  >
                    View Privacy Policy
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-3 h-3"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                </div>
              ))}
            </div>
          </section>

          <!-- 5. Data Security -->
          <section aria-labelledby="section-security">
            <h2 id="section-security" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">05.</span>
              Data Security
            </h2>
            <p>
              We value your trust and take reasonable technical and organisational measures to
              protect any information processed by our applications. All data transmissions are
              encrypted using industry-standard TLS/HTTPS. However, no method of transmission over
              the internet or electronic storage is 100% secure, and we cannot guarantee absolute
              security.
            </p>
          </section>

          <!-- 6. Data Retention -->
          <section aria-labelledby="section-retention">
            <h2 id="section-retention" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">06.</span>
              Data Retention
            </h2>
            <p>
              We retain personal data only for as long as necessary to fulfil the purposes described
              in this policy or as required by law. Diagnostic and analytics data is typically
              retained for no more than <strong class="text-zinc-200">24 months</strong>. You may
              request deletion of your data at any time by contacting us at
              <a
                href={`mailto:${contactEmail}`}
                class="text-blue-400 hover:text-blue-300 transition-colors">{contactEmail}</a
              >.
            </p>
          </section>

          <!-- 7. Children's Privacy -->
          <section aria-labelledby="section-children">
            <h2 id="section-children" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">07.</span>
              Children's Privacy
            </h2>
            <p>
              Our applications are <strong class="text-zinc-200">not directed at children under the age of 13</strong>.
              We do not knowingly collect personal information from children under 13. If you are a
              parent or guardian and believe your child has provided us with personal information,
              please contact us immediately at
              <a
                href={`mailto:${contactEmail}`}
                class="text-blue-400 hover:text-blue-300 transition-colors">{contactEmail}</a
              >, and we will take steps to delete such information promptly.
            </p>
            <p class="mt-3">
              If a specific app is designed for a younger audience, a separate, compliant privacy
              notice will be provided for that app and it will not collect personal data.
            </p>
          </section>

          <!-- 8. Your Rights -->
          <section aria-labelledby="section-rights">
            <h2 id="section-rights" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">08.</span>
              Your Rights
            </h2>
            <p>
              Depending on your location, you may have the following rights regarding your personal
              data:
            </p>
            <ul class="mt-3 space-y-2 list-none pl-0">
              {[
                { right: 'Right to Access', desc: 'Request a copy of the data we hold about you.' },
                { right: 'Right to Rectification', desc: 'Request correction of inaccurate data.' },
                { right: 'Right to Erasure', desc: '"Right to be forgotten" — request deletion of your data.' },
                { right: 'Right to Restrict Processing', desc: 'Ask us to limit how we use your data.' },
                { right: 'Right to Data Portability', desc: 'Receive your data in a portable format.' },
                { right: 'Right to Opt-Out (CCPA)', desc: 'California residents may opt out of the sale of personal information. We do not sell personal information.' },
              ].map((item) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  <span>
                    <strong class="text-zinc-200">{item.right}:</strong> {item.desc}
                  </span>
                </li>
              ))}
            </ul>
            <p class="mt-4">
              To exercise any of these rights, contact us at
              <a
                href={`mailto:${contactEmail}`}
                class="text-blue-400 hover:text-blue-300 transition-colors">{contactEmail}</a
              >. We will respond within <strong class="text-zinc-200">30 days</strong>.
            </p>
          </section>

          <!-- 9. Links to Other Sites -->
          <section aria-labelledby="section-links">
            <h2 id="section-links" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">09.</span>
              Links to Other Sites
            </h2>
            <p>
              Our applications may contain links to external websites or services (e.g., Google Play
              Store, job listing sites). These external sites are not operated by us, and we have no
              control over their content or privacy practices. We strongly advise you to review the
              privacy policy of any site you visit.
            </p>
          </section>

          <!-- 10. Changes to This Policy -->
          <section aria-labelledby="section-changes">
            <h2 id="section-changes" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">10.</span>
              Changes to This Privacy Policy
            </h2>
            <p>
              We may update this Privacy Policy from time to time. When we do, we will revise the
              "Effective Date" at the top of this page and, where appropriate, notify users through
              the application. We encourage you to review this policy periodically. Your continued
              use of our applications after any changes indicates your acceptance of the updated
              policy.
            </p>
          </section>

          <!-- 11. Contact -->
          <section aria-labelledby="section-contact">
            <h2 id="section-contact" class="text-xl font-bold text-white mb-3 flex items-center gap-2">
              <span class="text-blue-400 font-mono text-base">11.</span>
              Contact Us
            </h2>
            <p>
              If you have any questions, concerns, or requests regarding this Privacy Policy or our
              data practices, please reach out:
            </p>
            <div
              class="mt-5 rounded-xl bg-zinc-900 border border-zinc-800 p-5 flex items-start gap-4"
            >
              <div
                class="w-10 h-10 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center flex-shrink-0"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-blue-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-zinc-200 font-semibold text-sm">{developerName}</p>
                <a
                  href={`mailto:${contactEmail}`}
                  class="text-blue-400 hover:text-blue-300 text-sm transition-colors mt-0.5 block"
                >
                  {contactEmail}
                </a>
                <a
                  href={websiteUrl}
                  class="text-zinc-500 hover:text-zinc-300 text-xs transition-colors mt-0.5 block"
                >
                  {websiteUrl}
                </a>
              </div>
            </div>
          </section>
        </div>

        <!-- Bottom CTA -->
        <div class="mt-14 pt-10 border-t border-white/5 text-center">
          <p class="text-zinc-500 text-sm mb-4">
            Have more questions? We're always happy to help.
          </p>
          <a
            href={`mailto:${contactEmail}`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold transition-all duration-200 shadow-lg shadow-blue-500/20"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            Contact Support
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
